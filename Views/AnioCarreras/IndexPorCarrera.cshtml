@model IEnumerable<Inscripciones.Models.AnioCarrera>

@{
    ViewData["Title"] = "Index";
    int idcarrera = ViewBag.IdCarrera;
}

<h1>Mostrando Años de Carrera</h1>

<p>
    <a asp-action="CreatePorCarrera" asp-route-idcarrera="" style="color: black; background-color: #90EE90; padding: 5px 10px; text-decoration: none; border-radius: 5px; font-weight: bold; transition: background-color 0.3s;">Crear Nueva</a>
</p>
<form asp-controller="AnioCarreras" asp-action="IndexPorCarrera" method="post">
    <div class="form-group">
        <label asp-for="@idcarrera" class="control-label"></label>
        <select asp-for="@idcarrera" disabled class="form-control" asp-items="ViewBag.Carreras" onchange="this.form.submit()"></select>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Carrera)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Carrera.Nombre)
            </td>
                <td>
                    <a asp-controller="Materias" asp-action="IndexPorAnio" asp-route-idanio="@item.Id" class="materias-link">Materias</a>

                    <a asp-action="Edit" asp-route-id="@item.Id" class="edit-link">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="details-link">Detalles</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="delete-link">Eliminar</a>
                </td>

        </tr>
}
    </tbody>
</table>

<a asp-controller="Carreras" asp-action="Index">Volver</a>

